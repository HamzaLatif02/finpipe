# Flask
SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=production
PORT=8000

# Anthropic (optional — enables AI chart descriptions)
ANTHROPIC_API_KEY=

# Resend (optional — enables email report delivery)
RESEND_API_KEY=
RESEND_TO_OVERRIDE=

# PostgreSQL (optional — enables scheduled job persistence across restarts)
# Leave empty to use SQLite only (scheduled jobs reset on container restart)
DATABASE_URL=

# Rate limiting
RATELIMIT_STORAGE_URI=memory://

# Admin
ADMIN_TOKEN=change-this-to-a-random-string

# Scheduling
RENDER_EXTERNAL_URL=http://localhost:8000
